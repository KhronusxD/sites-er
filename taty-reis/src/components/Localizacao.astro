---
import { taty } from '../data/taty';

const mapSrc = `https://www.google.com/maps?q=${taty.maps.embedQuery}&output=embed`;
---

<section id="localizacao" class="py-20 sm:py-24">
  <div class="container-narrow grid gap-10 md:grid-cols-2 md:gap-14">
    <div>
      <span class="eyebrow">Onde estamos</span>
      <h2 class="heading-serif mt-4 text-3xl sm:text-4xl md:text-5xl">
        No coração do <span class="italic text-honey-500">bairro Da Paz</span>
      </h2>

      <address class="mt-6 not-italic">
        <p class="text-base text-coffee-800 leading-relaxed">
          {taty.endereco.rua}<br />
          {taty.endereco.bairro}<br />
          {taty.endereco.cidade}/{taty.endereco.estado} — CEP {taty.endereco.cep}
        </p>
      </address>

      <a
        href={taty.maps.link}
        target="_blank"
        rel="noopener"
        class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-honey-600 hover:text-honey-500"
      >
        Abrir no Google Maps
        <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
          <path d="M11 3a1 1 0 100 2h2.6L8.3 10.3a1 1 0 101.4 1.4L15 6.4V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z"/>
          <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 100-2H5z"/>
        </svg>
      </a>

      <div class="mt-10 rounded-2xl border border-coffee-800/8 bg-sand-50 p-6">
        <h3 class="heading-serif text-xl">Horário de atendimento</h3>
        <p class="mt-1 text-xs text-coffee-500">Atendimento sempre por agendamento</p>
        <ul class="mt-4 divide-y divide-coffee-800/8 text-sm">
          {taty.horarios.map((h) => (
            <li class="flex items-center justify-between py-2.5">
              <span class="text-coffee-600">{h.dia}</span>
              <span
                class={`font-medium ${
                  h.horario === 'Fechado' ? 'text-coffee-500' : 'text-coffee-800'
                }`}
              >
                {h.horario}
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div>
      <div class="overflow-hidden rounded-2xl shadow-soft ring-1 ring-coffee-800/5">
        <iframe
          src={mapSrc}
          title="Mapa Taty Reis Estética, Cabelo e Bronze"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="block h-[420px] w-full md:h-[520px]"
          allowfullscreen
        ></iframe>
      </div>
      <p class="mt-3 text-center text-xs text-coffee-500">
        Acesso pela Rua Comandante Nathaniel Albuquerque, no bairro Da Paz
      </p>
    </div>
  </div>
</section>
