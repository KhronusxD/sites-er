---
import { taty, whatsappLink } from '../data/taty';
import RatingPill from './RatingPill.astro';
---

<section id="topo" class="relative overflow-hidden">
  <div
    class="pointer-events-none absolute inset-0 -z-10 [background:radial-gradient(75%_60%_at_85%_15%,#F0D6A6_0%,transparent_55%),radial-gradient(55%_55%_at_5%_90%,#F0E5D2_0%,transparent_60%)]"
  >
  </div>

  <div class="container-narrow grid items-center gap-10 py-14 sm:py-20 md:grid-cols-[1.05fr_0.95fr] md:py-24 lg:gap-14">
    <div class="order-2 md:order-1">
      <RatingPill />

      <h1 class="heading-serif mt-5 text-4xl leading-[1.05] sm:text-5xl md:text-[3.4rem] lg:text-6xl">
        Estética, cabelo e bronze,
        <span class="block italic text-honey-500">com o cuidado que rende 4.9 no Google</span>
      </h1>

      <p class="mt-6 max-w-xl text-base text-coffee-600 sm:text-lg">
        Mais de uma década de experiência, no bairro Da Paz em Manaus.
        Atendimento exclusivo por agendamento, em um ambiente pensado
        pra você se sentir bem do começo ao fim.
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
        <a href={whatsappLink()} target="_blank" rel="noopener" class="btn-gold">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.5 14.4c-.3-.1-1.7-.8-1.9-.9-.3-.1-.5-.1-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5 0-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.1.2 2.1 3.3 5.2 4.6.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 1.9-1.4.2-.7.2-1.3.2-1.4-.1-.1-.3-.2-.6-.3z"></path>
            <path d="M12 0C5.4 0 0 5.4 0 12c0 2.1.6 4.1 1.6 5.9L0 24l6.3-1.6c1.7 1 3.7 1.5 5.7 1.5 6.6 0 12-5.4 12-12S18.6 0 12 0zm0 21.8c-1.8 0-3.6-.5-5.1-1.4l-.4-.2-3.8 1 1-3.7-.2-.4c-1-1.6-1.5-3.4-1.5-5.2C2 6.5 6.5 2 12 2s10 4.5 10 10-4.5 9.8-10 9.8z"></path>
          </svg>
          Agendar pelo WhatsApp
        </a>
        <a href="#pilares" class="btn-secondary">Conhecer os serviços</a>
      </div>

      <div class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-2 text-xs text-coffee-500">
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-honey-500" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.7-9.3a1 1 0 00-1.4-1.4L9 10.6 7.7 9.3a1 1 0 00-1.4 1.4l2 2a1 1 0 001.4 0l4-4z" clip-rule="evenodd"/></svg>
          Atendimento por agendamento
        </span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="h-3.5 w-3.5 text-honey-500" viewBox="0 0 20 20" fill="currentColor"><path d="M10 2a6 6 0 00-6 6c0 4.5 6 10 6 10s6-5.5 6-10a6 6 0 00-6-6zm0 8a2 2 0 110-4 2 2 0 010 4z"/></svg>
          {taty.endereco.bairro}, {taty.endereco.cidade}
        </span>
      </div>
    </div>

    <div class="order-1 md:order-2">
      <div class="relative">
        <div
          class="photo-frame aspect-[4/5] w-full rounded-[28px] shadow-soft ring-1 ring-coffee-800/5"
        >
          <img
            src={taty.imagens.hero}
            alt="Mulher com cabelos longos e bem cuidados"
            width="900"
            height="1125"
            loading="eager"
            decoding="async"
          />
          <span class="placeholder-tag">Foto Taty</span>
        </div>

        <div
          class="absolute -bottom-6 -left-6 hidden h-32 w-32 rounded-[20px] bg-honey-300/25 ring-1 ring-honey-400/30 backdrop-blur sm:block"
        ></div>
        <div
          class="absolute -right-4 -top-4 hidden h-20 w-20 rounded-full bg-bronze-300/40 sm:block"
        ></div>
      </div>
    </div>
  </div>
</section>
