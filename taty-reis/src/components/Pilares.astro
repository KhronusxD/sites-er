---
import { taty, whatsappLink } from '../data/taty';

const icones: Record<string, string> = {
  estetica:
    'M12 3.5c2.5 0 4.5 2 4.5 4.5 0 1.7-.9 3.2-2.3 4l2.3 5L12 14l-4.5 3 2.3-5C8.4 11.2 7.5 9.7 7.5 8c0-2.5 2-4.5 4.5-4.5z',
  cabelo:
    'M5 14c0-5 3.1-9 7-9s7 4 7 9c0 2-1 4-3 4H8c-2 0-3-2-3-4zm3 5h8',
  bronze:
    'M12 2v3M4.6 4.6l2.1 2.1M2 12h3M19 12h3M17.3 6.7l2.1-2.1M12 7a5 5 0 100 10 5 5 0 000-10z',
};
---

<section id="pilares" class="py-20 sm:py-24">
  <div class="container-narrow">
    <div class="max-w-2xl">
      <span class="eyebrow">Três especialidades</span>
      <h2 class="heading-serif mt-4 text-3xl sm:text-4xl md:text-5xl">
        Tudo o que você precisa <span class="italic text-honey-500">num só lugar</span>
      </h2>
      <p class="mt-5 text-base text-coffee-600">
        Estética, cabelo e bronzeamento artificial — cada serviço feito
        com produtos profissionais e o tempo que ele merece.
      </p>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-3">
      {taty.pilares.map((p, i) => (
        <article class="group relative overflow-hidden rounded-2xl border border-coffee-800/8 bg-sand-50 shadow-soft transition hover:-translate-y-0.5 hover:border-honey-400/50 hover:shadow-glow">
          <div class="photo-frame aspect-[4/3] w-full">
            <img
              src={p.img}
              alt={p.titulo}
              width="900"
              height="675"
              loading="lazy"
              decoding="async"
            />
            <span class="absolute right-3 top-3 z-10 inline-flex items-center gap-1 rounded-full bg-sand-50/95 px-2.5 py-1 text-[10px] font-medium uppercase tracking-widerish text-coffee-700">
              0{i + 1}
            </span>
          </div>

          <div class="p-6">
            <div class="flex items-center gap-3">
              <span class="grid h-9 w-9 place-items-center rounded-full bg-honey-300/30 text-honey-600">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d={icones[p.slug]}/>
                </svg>
              </span>
              <h3 class="heading-serif text-2xl">{p.titulo}</h3>
            </div>

            <p class="mt-3 text-sm text-coffee-600 leading-relaxed">{p.descricao}</p>

            <ul class="mt-5 space-y-1.5 text-sm text-coffee-700">
              {p.procedimentos.map((proc) => (
                <li class="flex items-start gap-2">
                  <svg class="mt-1 h-3 w-3 flex-shrink-0 text-honey-500" viewBox="0 0 12 12" fill="currentColor">
                    <circle cx="6" cy="6" r="3"/>
                  </svg>
                  <span>{proc}</span>
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-12 flex flex-col items-start gap-4 rounded-2xl border border-coffee-800/8 bg-sand-50 p-6 sm:flex-row sm:items-center sm:justify-between sm:p-8">
      <div>
        <p class="heading-serif text-xl sm:text-2xl">
          Quer combinar mais de um serviço?
        </p>
        <p class="mt-1 text-sm text-coffee-600">
          A gente monta o melhor horário pra você. Fala com a Taty no WhatsApp.
        </p>
      </div>
      <a
        href={whatsappLink('Olá Taty! Quero combinar mais de um serviço — pode me ajudar a montar o horário?')}
        target="_blank"
        rel="noopener"
        class="btn-primary"
      >
        Falar com a Taty
      </a>
    </div>
  </div>
</section>
