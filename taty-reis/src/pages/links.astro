---
import Layout from '../layouts/Layout.astro';
import { taty, whatsappLink } from '../data/taty';
import RatingPill from '../components/RatingPill.astro';

const seoLinks = {
  title: `Links · ${taty.nome}`,
  description: `Todos os canais da ${taty.nomeCurto} — WhatsApp, localização, avaliações e site. Marque seu horário pelo WhatsApp.`,
};

const stars = Math.round(taty.rating.valor);

const links = [
  {
    href: whatsappLink(),
    titulo: 'Agendar pelo WhatsApp',
    descricao: taty.whatsapp.e164,
    icone: 'whatsapp',
    estilo: 'primary',
    externo: true,
  },
  {
    href: taty.maps.link,
    titulo: 'Como chegar',
    descricao: `${taty.endereco.rua} · ${taty.endereco.bairro}`,
    icone: 'map',
    estilo: 'default',
    externo: true,
  },
  {
    href: taty.maps.link,
    titulo: `Avaliações no Google · ⭐ ${taty.rating.valor.toFixed(1)}`,
    descricao: `${taty.rating.total} clientes avaliaram`,
    icone: 'star',
    estilo: 'default',
    externo: true,
  },
  {
    href: '/',
    titulo: 'Conhecer o site',
    descricao: 'Serviços, galeria e depoimentos',
    icone: 'globe',
    estilo: 'default',
    externo: false,
  },
  {
    href: `tel:+${taty.whatsapp.raw}`,
    titulo: 'Ligar agora',
    descricao: taty.whatsapp.e164,
    icone: 'phone',
    estilo: 'default',
    externo: false,
  },
];
---

<Layout title={seoLinks.title} description={seoLinks.description}>
  <main class="relative min-h-screen overflow-hidden">
    <div
      class="pointer-events-none absolute inset-0 -z-10 [background:radial-gradient(75%_55%_at_85%_5%,#F0D6A6_0%,transparent_55%),radial-gradient(60%_55%_at_10%_95%,#F0E5D2_0%,transparent_60%)]"
    >
    </div>

    <div class="mx-auto flex min-h-screen w-full max-w-md flex-col px-5 py-10 sm:py-14">
      <header class="flex flex-col items-center text-center">
        <div class="relative">
          <div class="photo-frame h-28 w-28 rounded-full shadow-soft ring-4 ring-sand-50">
            <img
              src={taty.imagens.hero}
              alt={taty.nome}
              width="224"
              height="224"
              loading="eager"
              decoding="async"
            />
          </div>
          <span
            class="absolute -bottom-1 -right-1 grid h-9 w-9 place-items-center rounded-full bg-honey-400 text-coffee-900 ring-4 ring-sand-50"
            aria-hidden="true"
          >
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path d="M10 1.5l2.6 5.3 5.9.9-4.3 4.2 1 5.9L10 14.9l-5.3 2.8 1-5.9L1.4 7.7l5.9-.9L10 1.5z" />
            </svg>
          </span>
        </div>

        <h1 class="heading-serif mt-5 text-3xl sm:text-[2rem]">{taty.nomeCurto}</h1>
        <p class="mt-1 text-xs uppercase tracking-widerish text-coffee-500">
          {taty.tagline}
        </p>

        <p class="mt-3 max-w-xs text-sm text-coffee-600">
          {taty.endereco.bairro}, {taty.endereco.cidade}/{taty.endereco.estado} · atendimento por agendamento
        </p>

        <div class="mt-5">
          <RatingPill />
        </div>
      </header>

      <nav class="mt-10 space-y-3" aria-label="Principais links">
        {
          links.map((link) => {
            const base =
              'group flex items-center gap-4 rounded-2xl border px-5 py-4 shadow-soft transition active:scale-[0.98]';
            const primary =
              'border-honey-400/40 bg-gradient-to-r from-honey-400 to-honey-500 text-coffee-900 hover:from-honey-300 hover:to-honey-400';
            const def =
              'border-coffee-800/8 bg-sand-50 text-coffee-800 hover:border-honey-400/50 hover:bg-sand-100';
            const cls = `${base} ${link.estilo === 'primary' ? primary : def}`;
            const target = link.externo ? '_blank' : undefined;
            const rel = link.externo ? 'noopener' : undefined;

            return (
              <a href={link.href} target={target} rel={rel} class={cls}>
                <span
                  class={`grid h-10 w-10 flex-shrink-0 place-items-center rounded-full ${
                    link.estilo === 'primary'
                      ? 'bg-coffee-800/15 text-coffee-900'
                      : 'bg-honey-300/30 text-honey-600'
                  }`}
                >
                  {link.icone === 'whatsapp' && (
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M17.5 14.4c-.3-.1-1.7-.8-1.9-.9-.3-.1-.5-.1-.7.1-.2.3-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.2-.3.3-.5 0-.2 0-.4 0-.5 0-.1-.7-1.6-.9-2.2-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.1.2 2.1 3.3 5.2 4.6.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 1.9-1.4.2-.7.2-1.3.2-1.4-.1-.1-.3-.2-.6-.3z" />
                      <path d="M12 0C5.4 0 0 5.4 0 12c0 2.1.6 4.1 1.6 5.9L0 24l6.3-1.6c1.7 1 3.7 1.5 5.7 1.5 6.6 0 12-5.4 12-12S18.6 0 12 0zm0 21.8c-1.8 0-3.6-.5-5.1-1.4l-.4-.2-3.8 1 1-3.7-.2-.4c-1-1.6-1.5-3.4-1.5-5.2C2 6.5 6.5 2 12 2s10 4.5 10 10-4.5 9.8-10 9.8z" />
                    </svg>
                  )}
                  {link.icone === 'map' && (
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 22s-7-7.5-7-12a7 7 0 0114 0c0 4.5-7 12-7 12z"/>
                      <circle cx="12" cy="10" r="2.5"/>
                    </svg>
                  )}
                  {link.icone === 'star' && (
                    <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                      <path d="M10 1.5l2.6 5.3 5.9.9-4.3 4.2 1 5.9L10 14.9l-5.3 2.8 1-5.9L1.4 7.7l5.9-.9L10 1.5z"/>
                    </svg>
                  )}
                  {link.icone === 'globe' && (
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="9"/>
                      <path d="M3 12h18M12 3a14 14 0 010 18M12 3a14 14 0 000 18"/>
                    </svg>
                  )}
                  {link.icone === 'phone' && (
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.13.96.37 1.9.72 2.78a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.3-1.3a2 2 0 012.11-.45c.88.35 1.82.59 2.78.72A2 2 0 0122 16.92z"/>
                    </svg>
                  )}
                </span>

                <span class="flex flex-1 flex-col text-left leading-tight">
                  <span class="text-sm font-semibold sm:text-[15px]">{link.titulo}</span>
                  <span
                    class={`text-xs ${
                      link.estilo === 'primary' ? 'text-coffee-900/70' : 'text-coffee-500'
                    }`}
                  >
                    {link.descricao}
                  </span>
                </span>

                <svg
                  class={`h-4 w-4 flex-shrink-0 transition group-hover:translate-x-0.5 ${
                    link.estilo === 'primary' ? 'text-coffee-900/70' : 'text-coffee-500'
                  }`}
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M7.3 4.3a1 1 0 011.4 0l5 5a1 1 0 010 1.4l-5 5a1 1 0 01-1.4-1.4L11.6 10 7.3 5.7a1 1 0 010-1.4z"
                    clip-rule="evenodd"
                  />
                </svg>
              </a>
            );
          })
        }
      </nav>

      <ul class="mt-10 grid grid-cols-3 gap-3 text-center">
        {taty.horarios
          .filter((h) => h.horario !== 'Fechado')
          .map((h) => (
            <li class="rounded-xl border border-coffee-800/8 bg-sand-50 p-3 text-xs">
              <p class="font-medium text-coffee-800">{h.dia.replace('Terça a ', 'Ter–')}</p>
              <p class="mt-1 text-coffee-500">{h.horario}</p>
            </li>
          ))}
      </ul>

      <footer class="mt-auto pt-10 text-center text-[11px] text-coffee-500">
        © {new Date().getFullYear()} {taty.nome}
      </footer>
    </div>
  </main>
</Layout>
