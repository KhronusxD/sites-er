---
import { studio } from '../data/studio';

const mapSrc = `https://www.google.com/maps?q=${studio.maps.embedQuery}&output=embed`;
---

<section id="localizacao" class="bg-bone-200/60 py-20 sm:py-24">
  <div class="container-narrow grid gap-10 md:grid-cols-2 md:gap-14">
    <div>
      <span class="eyebrow">Onde estamos</span>
      <h2 class="heading-serif mt-4 text-3xl sm:text-4xl md:text-5xl">
        Pertinho de você, na <span class="italic text-blush-500">Col. Santo Antônio</span>
      </h2>

      <address class="mt-6 not-italic">
        <p class="text-base text-ink-900 leading-relaxed">
          {studio.endereco.rua}<br />
          {studio.endereco.bairro}<br />
          {studio.endereco.cidade}/{studio.endereco.estado} — CEP {studio.endereco.cep}
        </p>
      </address>

      <a
        href={studio.maps.link}
        target="_blank"
        rel="noopener"
        class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-gold-600 hover:text-blush-500"
      >
        Abrir no Google Maps
        <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
          <path d="M11 3a1 1 0 100 2h2.6L8.3 10.3a1 1 0 101.4 1.4L15 6.4V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z"/>
          <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 100-2H5z"/>
        </svg>
      </a>

      <div class="mt-10 rounded-2xl border border-ink-900/8 bg-bone-50 p-6">
        <h3 class="heading-serif text-xl">Horário de atendimento</h3>
        <p class="mt-1 text-xs text-ink-500">Atendimento sempre por agendamento</p>
        <ul class="mt-4 divide-y divide-ink-900/8 text-sm">
          {studio.horarios.map((h) => (
            <li class="flex items-center justify-between py-2.5">
              <span class="text-ink-700">{h.dia}</span>
              <span
                class={`font-medium ${
                  h.horario === 'Fechado' ? 'text-ink-500' : 'text-ink-900'
                }`}
              >
                {h.horario}
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div>
      <div class="overflow-hidden rounded-2xl shadow-soft ring-1 ring-ink-900/5">
        <iframe
          src={mapSrc}
          title="Mapa do Studio Lorena Paiva"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="block h-[420px] w-full md:h-[520px]"
          allowfullscreen
        ></iframe>
      </div>
      <p class="mt-3 text-center text-xs text-ink-500">
        Estacionamento na rua · acesso fácil pela R. José Faustino
      </p>
    </div>
  </div>
</section>
