---
import { studio } from '../data/studio';
---

<section id="galeria" class="py-20 sm:py-24">
  <div class="container-narrow">
    <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
      <div class="max-w-xl">
        <span class="eyebrow">Galeria</span>
        <h2 class="heading-serif mt-4 text-3xl sm:text-4xl md:text-5xl">
          Um pouquinho do nosso <span class="italic text-blush-500">dia a dia</span>
        </h2>
        <p class="mt-5 text-base text-ink-700">
          Trabalhos recentes do studio. Em breve, mais novidades por aqui.
        </p>
      </div>
      <p class="text-xs uppercase tracking-widerish text-ink-500">
        9 espaços pra fotos reais
      </p>
    </div>

    <div class="mt-10 grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4">
      {studio.galeria.map((foto, i) => {
        const aspect =
          i % 5 === 0
            ? 'aspect-[3/4]'
            : i % 4 === 0
            ? 'aspect-square'
            : 'aspect-[4/5]';
        return (
          <figure
            class={`photo-frame ${aspect} rounded-2xl ring-1 ring-ink-900/5 shadow-soft`}
          >
            <img
              src={foto.img}
              alt={foto.legenda}
              width="700"
              height="875"
              loading="lazy"
              decoding="async"
            />
            <span class="placeholder-tag">Foto Lorena</span>
            <figcaption class="absolute inset-x-0 bottom-0 z-10 bg-gradient-to-t from-ink-900/75 via-ink-900/25 to-transparent p-3 pt-10">
              <span class="font-serif text-sm text-bone-50 italic">
                {foto.legenda}
              </span>
            </figcaption>
          </figure>
        );
      })}
    </div>
  </div>
</section>
