---
import { clinic, imagens } from '../data/clinic';
---

<section id="diferenciais" class="relative overflow-hidden bg-navy-700 py-20 text-bone-100 sm:py-24">
  <div
    class="aurora-bg pointer-events-none absolute -inset-16 opacity-40 [background:radial-gradient(60%_50%_at_85%_15%,#B8C8B1_0%,transparent_55%),radial-gradient(50%_50%_at_10%_90%,#6E8867_0%,transparent_60%),radial-gradient(30%_30%_at_50%_50%,rgba(184,200,177,0.25)_0%,transparent_70%)]"
  >
  </div>

  <div class="container-narrow relative grid gap-12 md:grid-cols-[1fr_1.1fr] md:gap-16">
    <div>
      <span class="eyebrow !text-sage-300">Tecnologia & diferenciais</span>
      <h2 class="heading-serif mt-4 text-3xl text-bone-50 sm:text-4xl md:text-5xl">
        Procedimento clínico de primeira linha,
        <span class="block italic text-sage-300">com a calma de uma boutique.</span>
      </h2>

      <div class="mt-8 overflow-hidden rounded-2xl ring-1 ring-bone-50/10">
        <div class="photo-frame glow-ring aspect-[4/3] w-full rounded-2xl">
          <img
            src={imagens.scanner}
            alt="Scanner intra-oral em uso"
            width="1200"
            height="900"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>

    <ul class="space-y-4">
      {clinic.diferenciais.map((d) => (
        <li class="rounded-2xl border border-bone-50/10 bg-bone-50/5 p-6 backdrop-blur transition hover:border-sage-300/40">
          <div class="flex items-baseline gap-4">
            <span class="font-mono text-xs text-sage-300">{d.kicker}</span>
            <h3 class="heading-serif text-2xl text-bone-50">{d.titulo}</h3>
          </div>
          <p class="mt-3 text-sm leading-relaxed text-bone-100/75">{d.descricao}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
