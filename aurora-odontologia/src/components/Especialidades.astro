---
import { clinic } from '../data/clinic';

const icones: Record<string, string> = {
  tooth: 'M12 3c-3 0-5 2-5 5 0 2 1 3 1 6s-1 6 1 6 1.5-3 3-3 1 3 3 3 0-3-1-6 1-4 1-6c0-3-2-5-3-5z',
  align: 'M4 7h16M4 12h12M4 17h16',
  sparkle: 'M12 3l1.6 4.8L18 9.4l-4.4 1.6L12 16l-1.6-5L6 9.4l4.4-1.6L12 3zm6 11l.8 2.4L21 17.2l-2.2.8L18 21l-.8-3-2.2-.8 2.2-.8L18 14z',
  wave: 'M3 12c2-3 4-3 6 0s4 3 6 0 4-3 6 0',
  leaf: 'M5 19c0-8 4-12 14-14-2 10-6 14-14 14zm0 0l9-9',
  child: 'M12 6a3 3 0 100-4 3 3 0 000 4zm-3 4c0-2 1.5-3 3-3s3 1 3 3v3l2 7h-3l-1-5h-2l-1 5H7l2-7v-3z',
  shield: 'M12 3l8 3v5c0 5-3 8-8 10-5-2-8-5-8-10V6l8-3z',
  gear: 'M12 8a4 4 0 100 8 4 4 0 000-8zm6 4c0-.4 0-.8-.1-1.2l2-1.6-2-3.5-2.4.9c-.6-.5-1.3-.9-2-1.2L13 3h-2l-.5 2.4c-.7.3-1.4.7-2 1.2l-2.4-.9-2 3.5 2 1.6c0 .4-.1.8-.1 1.2s0 .8.1 1.2l-2 1.6 2 3.5 2.4-.9c.6.5 1.3.9 2 1.2L11 21h2l.5-2.4c.7-.3 1.4-.7 2-1.2l2.4.9 2-3.5-2-1.6c.1-.4.1-.8.1-1.2z',
};
---

<section id="especialidades" class="py-20 sm:py-24">
  <div class="container-narrow">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-2xl">
        <span class="eyebrow">Especialidades</span>
        <h2 class="heading-serif mt-4 text-3xl sm:text-4xl md:text-5xl">
          Uma clínica, <em>oito frentes</em> de cuidado.
        </h2>
      </div>
      <p class="max-w-sm text-sm text-slate-500">
        Equipe multidisciplinar pra planejar e executar tudo num lugar
        só — sem encaminhamentos perdidos pelo caminho.
      </p>
    </div>

    <ul class="mt-12 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      {clinic.especialidades.map((e, i) => (
        <li class="card-glow group relative flex flex-col rounded-2xl border border-navy-700/10 bg-bone-50 p-5 transition hover:-translate-y-0.5 hover:border-sage-400/50 hover:shadow-soft">
          <span class="font-mono text-[11px] text-sage-600">
            {String(i + 1).padStart(2, '0')}
          </span>
          <span class="mt-3 grid h-10 w-10 place-items-center rounded-full bg-sage-200/60 text-sage-600">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d={icones[e.icone]}/>
            </svg>
          </span>
          <h3 class="heading-serif mt-4 text-xl">{e.titulo}</h3>
          <p class="mt-2 text-sm text-slate-500 leading-relaxed">{e.descricao}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
