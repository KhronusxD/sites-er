---
import { clinic } from '../data/clinic';
---

<section id="casos" class="bg-bone-200/50 py-20 sm:py-24">
  <div class="container-narrow">
    <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
      <div class="max-w-2xl">
        <span class="eyebrow">Casos clínicos</span>
        <h2 class="heading-serif mt-4 text-3xl sm:text-4xl md:text-5xl">
          Resultados que <em>contam uma história.</em>
        </h2>
        <p class="mt-5 text-base text-slate-500">
          Cada caso documentado com mock-up digital, planejamento e
          acompanhamento. Selecionamos quatro exemplos das frentes
          mais procuradas.
        </p>
      </div>
      <p class="pill">Conteúdo ilustrativo · demo</p>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-2">
      {clinic.casos.map((c, i) => (
        <article class="group overflow-hidden rounded-2xl border border-navy-700/10 bg-bone-50 shadow-soft">
          <div class="photo-frame aspect-[5/3] w-full">
            <img
              src={c.img}
              alt={c.titulo}
              width="900"
              height="540"
              loading="lazy"
              decoding="async"
            />
            <span class="ai-tag">Foto ilustrativa</span>
          </div>
          <div class="p-6">
            <p class="text-[11px] uppercase tracking-widerish text-sage-600">
              Caso {String(i + 1).padStart(2, '0')}
            </p>
            <h3 class="heading-serif mt-2 text-2xl">{c.titulo}</h3>
            <p class="mt-2 text-sm text-slate-500">{c.descricao}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
